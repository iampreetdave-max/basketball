# Sportradar API credentials
# Copy this file to .env and fill in your real keys. Do NOT commit .env.

# Sportradar NBA API key (used by databaseBuilder.py, PreMatch.py, anba.py)
SPORTRADAR_NBA_API_KEY=your_sportradar_nba_api_key_here

# Sportradar Odds Comparison API key (used by scrapeODDS.py, "upcoming odds.py", anba.py)
SPORTRADAR_ODDS_API_KEY=your_sportradar_odds_api_key_here
